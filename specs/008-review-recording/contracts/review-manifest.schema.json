{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://screenpro.app/schemas/review-manifest-v1.json",
  "title": "ScreenPro Review Report Manifest",
  "description": "Machine-readable review report produced by ScreenPro Review Recording (feature 008). This file is the integration contract for agentic coding tools: every issue is self-contained, with screenshot paths relative to the bundle folder containing this file.",
  "type": "object",
  "required": ["schemaVersion", "generator", "session", "issues"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generator": { "type": "string", "examples": ["ScreenPro"] },
    "session": {
      "type": "object",
      "required": ["recordedAt", "duration", "target"],
      "properties": {
        "recordedAt": { "type": "string", "format": "date-time" },
        "duration": { "type": "number", "minimum": 0, "description": "Recording length in seconds (pause-adjusted)." },
        "target": { "type": "string", "description": "Human descriptor of the recorded display/window/area." },
        "videoFile": { "type": ["string", "null"], "description": "Bundle-relative path to the recording, null when the user excluded the video." }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "index", "timestamp", "timecode", "source", "screenshot"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "index": { "type": "integer", "minimum": 1, "description": "1-based chronological position." },
          "timestamp": { "type": "number", "minimum": 0, "description": "Seconds into the video." },
          "timecode": { "type": "string", "pattern": "^[0-9]{2,}:[0-5][0-9]$", "examples": ["03:42"] },
          "source": { "enum": ["manual", "voice"] },
          "note": { "type": ["string", "null"], "description": "Text typed by the reviewer." },
          "transcript": { "type": ["string", "null"], "description": "What the reviewer said at this moment." },
          "screenshot": { "type": "string", "pattern": "^screenshots/", "description": "Bundle-relative PNG path showing the screen at this moment." }
        }
      }
    },
    "fullTranscript": {
      "type": ["array", "null"],
      "description": "Entire narration, present when the user included it.",
      "items": {
        "type": "object",
        "required": ["start", "end", "text"],
        "properties": {
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "minimum": 0 },
          "text": { "type": "string" }
        }
      }
    }
  }
}
